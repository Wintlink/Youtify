# Youtify - Configuration
# Copiez ce fichier en .env et remplissez vos identifiants

# Spotify API (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=votre_client_id_ici
SPOTIFY_CLIENT_SECRET=votre_client_secret_ici

# YouTube Music (chemin vers le fichier browser.json)
YOUTUBE_AUTH_FILE=browser.json
